# Configuración del navegador
HEADLESS=false

# URLs
QWEN_CHAT_URL=https://chat.qwen.ai/c/tu-chat-id-aqui
VEED_URL=https://www.veed.io

# Credenciales de Veed.io (si es necesario)
VEED_EMAIL=
VEED_PASSWORD=

# Configuración del video
VIDEO_TEMA=Explica un tema interesante de tecnología
VIDEO_DURACION=60

# Timeouts (en milisegundos)
# TIMEOUT_NAVIGATION: tiempo máximo para cargar páginas (120000ms = 2 minutos)
# TIMEOUT_GENERATION: tiempo máximo para generación de video (300000ms = 5 minutos)
TIMEOUT_NAVIGATION=120000
TIMEOUT_GENERATION=300000

# Puerto del servidor web
PORT=3000

# Puerto de noVNC para login remoto en VPS
NOVNC_PORT=6080

# ── Bot de Telegram ────────────────────────────────────────────────────────
# Token del bot (créalo con @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=

# Chat ID autorizado (opcional: si se deja vacío, se registra automáticamente
# al enviar /start por primera vez. Puedes obtenerlo con @userinfobot)
TELEGRAM_CHAT_ID=

# ── Google Sheets — Series ─────────────────────────────────────────────────
# ID de la hoja de Google Sheets (la parte entre /d/ y /edit en la URL)
GOOGLE_SHEET_ID=1CutBXAFfeu4UWZ0LOxl9p3lwN7D58TTftVVIMbjm6dk

# ── Facebook Meta Graph API ────────────────────────────────────────────────
# ID de la pagina de Facebook donde se subiran los Reels
FB_PAGE_ID=

# Access Token de Pagina con permisos de publicación (pages_manage_posts)
FB_ACCESS_TOKEN=
